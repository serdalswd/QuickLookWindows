<Window x:Class="QuickLookWindows.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Grid Background="#CC000000">

        <!-- Preview card -->
        <Border x:Name="CardBorder"
                Width="900" Height="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1C1C1E"
                CornerRadius="14"
                BorderBrush="#3A3A3C"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="60" Opacity="0.8" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="#2C2C2E"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#3A3A3C"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="#FF5F57" Margin="0,0,8,0"/>
                            <Ellipse Width="12" Height="12" Fill="#FEBC2E" Margin="0,0,8,0"/>
                            <Ellipse Width="12" Height="12" Fill="#28C840"/>
                        </StackPanel>
                        <TextBlock x:Name="TitleText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#EBEBF5"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="700"/>
                    </Grid>
                </Border>

                <!-- Content area -->
                <Grid Grid.Row="1" x:Name="ContentGrid"
                      Background="#1C1C1E"
                      ClipToBounds="True">
                    <TextBlock x:Name="LoadingText"
                               Text="Yükleniyor..."
                               Foreground="#8E8E93"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Info bar -->
                <Border Grid.Row="2"
                        Background="#2C2C2E"
                        CornerRadius="0,0,14,14"
                        BorderBrush="#3A3A3C"
                        BorderThickness="0,1,0,0">
                    <DockPanel Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="ESC / SPACE — kapat"
                                   DockPanel.Dock="Right"
                                   Foreground="#48484A"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="FileTypeLabel"
                                       Foreground="#8E8E93"
                                       FontSize="12"/>
                            <TextBlock x:Name="SeparatorDot"
                                       Text=" · "
                                       Foreground="#48484A"
                                       FontSize="12"/>
                            <TextBlock x:Name="FileSizeLabel"
                                       Foreground="#8E8E93"
                                       FontSize="12"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
