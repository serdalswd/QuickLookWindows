<Window x:Class="QuickLookWindows.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.4" Center="0.5,0.4" RadiusX="0.7" RadiusY="0.7">
                <GradientStop Color="#D4000010" Offset="0"/>
                <GradientStop Color="#E8000000" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Preview card -->
        <Border x:Name="CardBorder"
                Width="900" Height="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1C1C1E"
                CornerRadius="14"
                BorderThickness="1.5"
                RenderTransformOrigin="0.5,0.5"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform/>
            </Border.RenderTransform>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5558C8" Offset="0"/>
                    <GradientStop Color="#2A2A3C" Offset="0.45"/>
                    <GradientStop Color="#2A2A3C" Offset="0.55"/>
                    <GradientStop Color="#6B30A8" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#2020A0" BlurRadius="80" Opacity="0.55" ShadowDepth="0"/>
            </Border.Effect>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="CardBorder"
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1" Duration="0:0:0.22"/>
                            <DoubleAnimation
                                Storyboard.TargetName="CardBorder"
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                From="0.94" To="1" Duration="0:0:0.35">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetName="CardBorder"
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                From="0.94" To="1" Duration="0:0:0.35">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#3A3A3C"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2C2C38" Offset="0"/>
                            <GradientStop Color="#242432" Offset="0.5"/>
                            <GradientStop Color="#2C2C38" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="16,0">

                        <!-- Mac traffic lights -->
                        <StackPanel x:Name="TrafficLights"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    MouseEnter="TrafficLights_MouseEnter"
                                    MouseLeave="TrafficLights_MouseLeave">

                            <!-- Red: Close -->
                            <Grid Width="12" Height="12" Margin="0,0,8,0">
                                <Ellipse Fill="#FF5F57"/>
                                <TextBlock x:Name="CloseSymbol" Text="✕"
                                           FontSize="7.5" FontWeight="Bold"
                                           Foreground="#730000"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0" Margin="0,0.5,0,0"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Kapat"
                                        Click="BtnClose_Click" Focusable="False"/>
                            </Grid>

                            <!-- Yellow: Open with default app -->
                            <Grid Width="12" Height="12" Margin="0,0,8,0">
                                <Ellipse Fill="#FEBC2E"/>
                                <TextBlock x:Name="OpenSymbol" Text="↗"
                                           FontSize="7" FontWeight="Bold"
                                           Foreground="#6B4000"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Uygulamada Aç"
                                        Click="BtnOpenFile_Click" Focusable="False"/>
                            </Grid>

                            <!-- Green: Expand/contract card -->
                            <Grid Width="12" Height="12">
                                <Ellipse Fill="#28C840"/>
                                <TextBlock x:Name="ExpandSymbol" Text="⤢"
                                           FontSize="8" FontWeight="Bold"
                                           Foreground="#004D00"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Büyüt / Küçült"
                                        Click="BtnExpand_Click" Focusable="False"/>
                            </Grid>
                        </StackPanel>

                        <!-- File name -->
                        <TextBlock x:Name="TitleText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#EBEBF5"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="620"/>

                        <!-- Sibling navigation arrows -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnPrev"
                                    Content="‹"
                                    Background="Transparent" Foreground="#8E8E93"
                                    BorderThickness="0" FontSize="20" FontWeight="Bold"
                                    Width="28" Height="28" Cursor="Hand"
                                    ToolTip="Önceki dosya (←)"
                                    Click="BtnPrev_Click" Focusable="False"
                                    Visibility="Collapsed"/>
                            <Button x:Name="BtnNext"
                                    Content="›"
                                    Background="Transparent" Foreground="#8E8E93"
                                    BorderThickness="0" FontSize="20" FontWeight="Bold"
                                    Width="28" Height="28" Cursor="Hand"
                                    ToolTip="Sonraki dosya (→)"
                                    Click="BtnNext_Click" Focusable="False"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content area -->
                <Grid Grid.Row="1" x:Name="ContentGrid"
                      Background="#1C1C1E"
                      ClipToBounds="True">
                    <TextBlock x:Name="LoadingText"
                               Text="Yükleniyor..."
                               Foreground="#8E8E93"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Info bar -->
                <Border Grid.Row="2"
                        Background="#2C2C2E"
                        CornerRadius="0,0,14,14"
                        BorderBrush="#3A3A3C"
                        BorderThickness="0,1,0,0">
                    <DockPanel Margin="16,0" VerticalAlignment="Center">
                        <!-- Right side (declared first for DockPanel ordering) -->
                        <TextBlock x:Name="HintText"
                                   Text="ESC · SPACE kapat  ·  ← → gezin"
                                   DockPanel.Dock="Right"
                                   Foreground="#48484A"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnOpenInBar"
                                Content="Aç ↗"
                                DockPanel.Dock="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#6366F1"
                                FontSize="11"
                                Cursor="Hand"
                                Margin="0,0,20,0"
                                Padding="0"
                                Click="BtnOpenFile_Click"
                                Focusable="False"
                                VerticalAlignment="Center"/>
                        <!-- Left side: file info -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="FileTypeLabel"
                                       Foreground="#8E8E93"
                                       FontSize="12"/>
                            <TextBlock x:Name="SeparatorDot"
                                       Text=" · "
                                       Foreground="#48484A"
                                       FontSize="12"/>
                            <TextBlock x:Name="FileSizeLabel"
                                       Foreground="#8E8E93"
                                       FontSize="12"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
