<Window x:Class="QuickLookSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickLook for Windows — Kurulum"
        Width="540" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D0D0F"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#A1A1AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Sol renk çizgisi -->
        <Border Width="4" HorizontalAlignment="Left" Background="#6366F1" CornerRadius="0"/>

        <!-- İçerik -->
        <Grid Margin="48,36,40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sayfa 1: Karşılama -->
            <StackPanel x:Name="PageWelcome" Grid.Row="0" Grid.RowSpan="3">
                <TextBlock Text="QuickLook" FontSize="28" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,4"/>
                <TextBlock Text="for Windows" FontSize="14" Foreground="#6366F1"
                           FontWeight="Medium" Margin="0,0,0,32"/>
                <TextBlock TextWrapping="Wrap" Foreground="#A1A1AA" FontSize="14" LineHeight="22"
                           Margin="0,0,0,28">
                    Mac'in efsanevi <Run Foreground="White" FontWeight="SemiBold">Quick Look</Run> özelliği Windows'ta.&#x0a;&#x0a;File Explorer'da bir dosya seçin ve <Run Background="#1E1E24" Foreground="#A5B4FC" FontFamily="Cascadia Code, Consolas">SPACE</Run> tuşuna basın — resim, video, ses, kod dosyalarını anında önizleyin.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="7" Height="7" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Arka planda sistem tepsisinde çalışır" Foreground="#71717A" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="7" Height="7" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Resim, video, ses, metin, kod desteği" Foreground="#71717A" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,36">
                    <Ellipse Width="7" Height="7" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Windows başlangıcında otomatik başlar" Foreground="#71717A" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Devam →" Style="{StaticResource FlatButton}" Click="BtnNext_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Sayfa 2: Konum Seç -->
            <StackPanel x:Name="PageInstall" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                <TextBlock Text="Kurulum Konumu" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,8"/>
                <TextBlock Text="Uygulamanın kurulacağı klasörü seçin."
                           Foreground="#71717A" FontSize="13" Margin="0,0,0,28"/>

                <TextBlock Text="Kurulum klasörü" Foreground="#A1A1AA" FontSize="12"
                           FontWeight="Medium" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#18181B" BorderBrush="#27272A"
                            BorderThickness="1" CornerRadius="8,0,0,8">
                        <TextBox x:Name="TxtPath" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13"
                                 FontFamily="Cascadia Code, Consolas" VerticalContentAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" Content="Gözat" Click="BtnBrowse_Click"
                            Background="#27272A" Foreground="#A1A1AA"
                            BorderThickness="1" BorderBrush="#3F3F46"
                            Padding="14,10" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="0,8,8,0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3F3F46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <CheckBox x:Name="ChkDesktop" IsChecked="True" Foreground="#A1A1AA"
                          FontSize="13" Margin="0,0,0,10" Cursor="Hand">
                    <TextBlock Text="Masaüstüne kısayol oluştur" Foreground="#A1A1AA"/>
                </CheckBox>
                <CheckBox x:Name="ChkStartup" IsChecked="True" Foreground="#A1A1AA"
                          FontSize="13" Margin="0,0,0,32" Cursor="Hand">
                    <TextBlock Text="Windows başlangıcında otomatik çalıştır" Foreground="#A1A1AA"/>
                </CheckBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Geri" Style="{StaticResource GhostButton}" Click="BtnBack_Click" Margin="0,0,8,0"/>
                    <Button Content="Kur →" Style="{StaticResource FlatButton}" Click="BtnInstall_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Sayfa 3: Tamamlandı -->
            <StackPanel x:Name="PageDone" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                <TextBlock Text="✓" FontSize="48" Foreground="#22C55E"
                           HorizontalAlignment="Left" Margin="0,0,0,16"/>
                <TextBlock Text="Kurulum Tamamlandı!" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtDoneMsg" TextWrapping="Wrap"
                           Foreground="#71717A" FontSize="13" LineHeight="22" Margin="0,0,0,32"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Uygulamayı Başlat" Style="{StaticResource FlatButton}" Click="BtnLaunch_Click"/>
                    <Button Content="Kapat" Style="{StaticResource GhostButton}" Click="BtnClose_Click" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
